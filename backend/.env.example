# Copy this file to ".env" and adjust values as needed.

# Server port
PORT=5000

# MongoDB connection string.
# - Local MongoDB:  mongodb://127.0.0.1:27017/codealpha_ecommerce
# - MongoDB Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/codealpha_ecommerce
# If this can't be reached, the app automatically falls back to an in-memory
# MongoDB (mongodb-memory-server) so you can run it with zero setup.
MONGODB_URI=mongodb://127.0.0.1:27017/codealpha_ecommerce

# Secret used to sign JWT auth tokens (change this to any random string)
JWT_SECRET=super_secret_change_me
